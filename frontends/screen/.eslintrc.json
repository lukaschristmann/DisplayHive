{
  "env": {
    "browser": true,
    "es2021": true
  },
  "parserOptions": {
    "ecmaVersion": 12,
    "sourceType": "module"
  },
  "rules": {
    "no-restricted-syntax": [
      "error",
      {
        "selector": "MemberExpression[object.name='localStorage']",
        "message": "Direct access to localStorage is disallowed. Use the safe storage helpers in ts/common/storage.ts (get/set/remove) instead."
      }
    ]
  },
  "overrides": [
    {
      "files": ["ts/common/storage.ts"],
      "rules": {
        "no-restricted-syntax": "off"
      }
    }
    ,
    {
      "files": ["static/js/storage.js"],
      "rules": {
        "no-restricted-syntax": "off"
      }
    }
    ,
    {
      "files": ["**/*.ts", "**/*.d.ts"],
      "parser": "@typescript-eslint/parser",
      "parserOptions": {
        "project": "./tsconfig.json",
        "sourceType": "module"
      },
      "plugins": ["@typescript-eslint"]
    }
  ]
}
