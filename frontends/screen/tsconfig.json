{
  "compilerOptions": {
    "target": "ES2019",
    "module": "ESNext",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node",
    "outDir": "../../static/js-build",
    "sourceMap": true,
    "incremental": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": ["ts/**/*", "js/**/*"],
  "exclude": ["node_modules", "dist"]
}
