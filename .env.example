# Example environment settings for local development
# Add additional origins separated by commas (no spaces required).
# Example: CORS_ALLOWED_ORIGINS="https://localhost:4200,https://127.0.0.1:4200"

CORS_ALLOWED_ORIGINS="https://localhost:4200,https://127.0.0.1:4200
# The Werkzeug debugger is OFF by default (it allows remote code execution if
# exposed). Opt in for local development only with FLASK_DEBUG=1 — never on a
# network-reachable host.
# FLASK_DEBUG=1

# Number of reverse proxies in front of the app. Set this (e.g. 1 for a single
# nginx) so the login rate limiter sees the real client IP via X-Forwarded-For.
# Leave unset/0 when the app is reached directly, to avoid header spoofing.
# TRUSTED_PROXY_COUNT=1
