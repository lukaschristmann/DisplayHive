# Example environment for `docker compose`. Copy to `.env` and fill in values:
#   cp .env.example .env
# Generate the secrets with:  openssl rand -hex 32

# --- Required secrets ---------------------------------------------------------
# Flask session/JWT signing key. MUST be set to a long random string.
SECRET_KEY=change-me-to-a-long-random-string
# Password for the bundled PostgreSQL service (used by DATABASE_URL in compose).
POSTGRES_PASSWORD=change-me-to-a-strong-password

# --- Initial admin account (created on first start if no users exist) ---------
ADMIN_BOOTSTRAP_USERNAME=admin
ADMIN_BOOTSTRAP_PASSWORD=change-me

# --- Networking ---------------------------------------------------------------
# Allowed origins for the API / Socket.IO. Comma-separated, no spaces required.
# Use "*" for local testing only; set explicit https URLs in production.
# Example: CORS_ALLOWED_ORIGINS="https://localhost:4200,https://127.0.0.1:4200"
CORS_ALLOWED_ORIGINS=*
# Number of reverse proxies in front of the app. Set this (e.g. 1 for a single
# nginx) so the login rate limiter sees the real client IP via X-Forwarded-For.
# Leave 0 when the app is reached directly, to avoid header spoofing.
TRUSTED_PROXY_COUNT=0

# --- Logging ------------------------------------------------------------------
# One of DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO

# --- Local development only ---------------------------------------------------
# The Werkzeug debugger is OFF by default (it allows remote code execution if
# exposed). Opt in for local development only — never on a network-reachable host.
# FLASK_DEBUG=1
